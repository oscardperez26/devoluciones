generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model UsuarioAdmin {
  id            String   @id @default(uuid()) @db.UniqueIdentifier
  nombre        String
  correo        String   @unique
  passwordHash  String   @map("password_hash")
  rol           String
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("usuarios_admin")
}

model Pedido {
  id                String    @id @default(uuid()) @db.UniqueIdentifier
  numeroPedido      String    @unique @map("numero_pedido")
  correoCliente     String    @map("correo_cliente")
  correoClienteHash String    @map("correo_cliente_hash")
  nombreCliente     String    @map("nombre_cliente")
  estado            String
  total             Decimal   @db.Decimal(12, 2)
  moneda            String    @db.Char(3)
  fechaCompra       DateTime  @map("fecha_compra")
  fechaEntrega      DateTime? @map("fecha_entrega")
  externalId        String?   @map("external_id")
  metadata          String?
  creadoEn          DateTime  @default(now()) @map("creado_en")
  actualizadoEn     DateTime  @updatedAt @map("actualizado_en")

  items        PedidoItem[]
  devoluciones Devolucion[]

  @@map("pedidos")
}

model PedidoItem {
  id             String   @id @default(uuid()) @db.UniqueIdentifier
  pedidoId       String   @map("pedido_id") @db.UniqueIdentifier
  sku            String
  nombreProducto String   @map("nombre_producto")
  talla          String?
  color          String?
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(12, 2)
  cantidad       Int
  urlImagen      String?  @map("url_imagen")
  esDevolvible   Boolean  @default(true) @map("es_devolvible")
  fechaLimite    DateTime? @map("fecha_limite")

  pedido       Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  devoluciones DevolucionItem[]

  @@map("pedido_items")
}

model Devolucion {
  id                String    @id @default(uuid()) @db.UniqueIdentifier
  numeroTicket      String?   @map("numero_ticket")
  pedidoId          String    @map("pedido_id") @db.UniqueIdentifier
  correoClienteHash String    @map("correo_cliente_hash")
  estado            String    @default("BORRADOR")
  metodoEntrega     String?   @map("metodo_entrega")
  tiendaId          String?   @map("tienda_id") @db.UniqueIdentifier
  direccionEnvio    String?   @map("direccion_envio")
  metodoReembolso   String?   @map("metodo_reembolso")
  totalReembolso    Decimal?  @map("total_reembolso") @db.Decimal(12, 2)
  notas             String?
  codigoBono        String?   @map("codigo_bono")
  enviadaEn         DateTime? @map("enviada_en")
  creadoEn          DateTime  @default(now()) @map("creado_en")
  actualizadoEn     DateTime  @updatedAt @map("actualizado_en")

  pedido    Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  tienda    Tienda?           @relation(fields: [tiendaId], references: [id], onDelete: SetNull)
  items     DevolucionItem[]
  historial HistorialEstado[]

  @@map("devoluciones")
}

model DevolucionItem {
  id            String  @id @default(uuid()) @db.UniqueIdentifier
  devolucionId  String  @map("devolucion_id") @db.UniqueIdentifier
  pedidoItemId  String  @map("pedido_item_id") @db.UniqueIdentifier
  causales      String  @map("causales")
  comentarios   String?
  cantidad      Int     @default(1)
  valorUnitario Decimal @map("valor_unitario") @db.Decimal(12, 2)

  devolucion Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade,  onUpdate: NoAction)
  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evidencias Evidencia[]

  @@map("devolucion_items")
}

model Evidencia {
  id               String   @id @default(uuid()) @db.UniqueIdentifier
  devolucionItemId String   @map("devolucion_item_id") @db.UniqueIdentifier
  claveArchivo     String   @map("clave_archivo")
  bucket           String
  tipoMime         String   @map("tipo_mime")
  tamanioBytes     Int      @map("tamanio_bytes")
  esValido         Boolean  @default(true) @map("es_valido")
  creadoEn         DateTime @default(now()) @map("creado_en")

  devolucionItem DevolucionItem @relation(fields: [devolucionItemId], references: [id], onDelete: Cascade)

  @@map("evidencias")
}

model HistorialEstado {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  devolucionId   String    @map("devolucion_id") @db.UniqueIdentifier
  estadoAnterior String?   @map("estado_anterior")
  estadoNuevo    String    @map("estado_nuevo")
  cambiadoPor    String    @map("cambiado_por")
  notas          String?
  creadoEn       DateTime  @default(now()) @map("creado_en")

  devolucion Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)

  @@map("historial_estados")
}

model Tienda {
  id           String  @id @default(uuid()) @db.UniqueIdentifier
  nombre       String
  direccion    String
  ciudad       String
  departamento String
  telefono     String?
  horario      String?
  activo       Boolean @default(true)

  devoluciones Devolucion[]

  @@map("tiendas")
}

model CausalDevolucion {
  id                String   @id @default(uuid()) @db.UniqueIdentifier
  codigo            String   @unique
  label             String
  grupo             String
  plazosDias        Int      @map("plazos_dias")
  requiereEvidencia Boolean  @map("requiere_evidencia")
  orden             Int      @default(0)
  activo            Boolean  @default(true)
  creadoEn          DateTime @default(now()) @map("creado_en")
  actualizadoEn     DateTime @updatedAt @map("actualizado_en")

  @@map("causales_devolucion")
}

model Auditoria {
  id          String   @id @default(uuid()) @db.UniqueIdentifier
  accion      String
  actor       String
  tipoRecurso String?  @map("tipo_recurso")
  idRecurso   String?  @map("id_recurso") @db.UniqueIdentifier
  ip          String?
  userAgent   String?  @map("user_agent")
  metadata    String?
  creadoEn    DateTime @default(now()) @map("creado_en")

  @@map("auditoria")
}
