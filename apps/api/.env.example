# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Base de datos (SQL Server) ────────────────────────────────────────────────
DATABASE_URL="sqlserver://HOST:PORT;database=DB_NAME;user=USER;password=PASSWORD;trustServerCertificate=true"
DB_HOST=HOST
DB_PORT=1433
DB_USER=USER
DB_PASSWORD=PASSWORD
DB_NAME=DB_NAME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT / Secretos ────────────────────────────────────────────────────────────
# Mínimo 64 caracteres aleatorios. Generar con: openssl rand -hex 32
RETURN_ACCESS_SECRET=cambia_esto_por_un_secreto_de_al_menos_64_caracteres_aleatorios_1234
ADMIN_JWT_SECRET=cambia_esto_por_otro_secreto_de_al_menos_64_caracteres_aleatorios_5678

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Sin espacios alrededor de las comas.
# Ejemplo producción: https://app.ogloba.com,https://admin.ogloba.com
ALLOWED_ORIGINS=https://tu-frontend.com,https://admin.tu-frontend.com

# ── Almacenamiento S3 / R2 ────────────────────────────────────────────────────
S3_BUCKET=nombre-del-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=SECRET_ACCESS_KEY
# Opcional — solo para MinIO u otros compatibles con S3
# S3_ENDPOINT=https://tu-endpoint.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tu-dominio.com

# ── Puerto del servidor ───────────────────────────────────────────────────────
PORT=3001
